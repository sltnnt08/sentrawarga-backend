		{
			"name": "Auth",
			"item": [
				{
					"name": "Register",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"pm.environment.set('testEmail', `postman.${Date.now()}@example.com`);",
									"pm.environment.unset('accessToken');",
									"pm.environment.unset('reportId');",
									"pm.environment.unset('notificationId');"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Register success status', function () {",
									"  pm.expect(pm.response.code).to.eql(201);",
									"});",
									"const json = pm.response.json();",
									"pm.test('Register returns access token and user', function () {",
									"  pm.expect(json.success).to.eql(true);",
									"  pm.expect(json.data.accessToken).to.be.a('string');",
									"  pm.expect(json.data.user.id).to.be.a('string');",
									"});",
									"pm.environment.set('accessToken', json.data.accessToken);",
									"pm.environment.set('userId', json.data.user.id);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"{{testName}}\",\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\",\n  \"address\": \"{{testAddress}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "register"]
						}
					},
					"response": []
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Login success status', function () {",
									"  pm.expect(pm.response.code).to.eql(200);",
									"});",
									"const json = pm.response.json();",
									"pm.test('Login returns access token and user', function () {",
									"  pm.expect(json.success).to.eql(true);",
									"  pm.expect(json.data.accessToken).to.be.a('string');",
									"  pm.expect(json.data.user.id).to.be.a('string');",
									"});",
									"pm.environment.set('accessToken', json.data.accessToken);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
