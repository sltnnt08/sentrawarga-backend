model Report {
    id           String        @id @default(uuid())
    title        String
    description  String
    feedback     String?
    priority     Priority
    resolvedAt   DateTime?
    createdAt    DateTime      @default(now())
    updatedAt    DateTime      @updatedAt
    reporterId   String
    status       ReportStatus
    category     Category[]
    address      String?
    longitude    Float?
    latitude     Float?
    aiCategory   Category?
    aiConfidence Float?
    aiSpamFlag   Boolean?
    cancelledByRole Role?
    cancelledAt DateTime?
    editedByReporter Boolean @default(false)
    lastEditedByReporterAt DateTime?
    comments     Comment[]
    reporter     User          @relation(fields: [reporterId], references: [id])
    reportImages ReportImage[]
    votes        Vote[]

    @@index([createdAt(sort: Desc)])
    @@index([status, createdAt(sort: Desc)])
    @@index([priority, createdAt(sort: Desc)])
    @@index([reporterId, createdAt(sort: Desc)])
}
