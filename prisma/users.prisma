model User {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  password      String
  role          Role           @default(USER)
  address       String?
  comments      Comment[]
  notifications Notification[]
  reports       Report[]
  votes         Vote[]
}
