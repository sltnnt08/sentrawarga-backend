# App
NODE_ENV=development
PORT=3000

# Database
# Supabase Postgres (Direct connection, SSL required)
# Example format:
# postgresql://postgres.[PROJECT_REF]:[DB_PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=

# Optional local fallback
LOCAL_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sentrawarga?schema=public

# CORS
# Single origin or comma-separated allowlist
CORS_ORIGIN=http://localhost:5173

# Auth
# Must be at least 16 characters
JWT_SECRET=change-this-jwt-secret
JWT_EXPIRES_IN=1d

# Request body
BODY_LIMIT=1mb

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=20

# Proxy
TRUST_PROXY=false
