# App
NODE_ENV=development
PORT=3000

# Database
# Supabase Postgres (Direct connection, SSL required)
# Example format:
# postgresql://postgres.[PROJECT_REF]:[DB_PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=

# Direct (non-pooling) connection for Prisma migrations
DIRECT_URL=

# Optional local fallback
LOCAL_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sentrawarga?schema=public

# CORS
# Single origin or comma-separated allowlist
CORS_ORIGIN=http://localhost:5173,https://sentrawarga.my.id,https://www.sentrawarga.my.id

# Auth
# Must be at least 16 characters
# Generate with: npm run gen:jwt-secret
JWT_SECRET=change-this-jwt-secret
JWT_EXPIRES_IN=1d

# Request body
BODY_LIMIT=1mb

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=20

# Email Service (SendPulse SMTP)
# Leave SMTP USER/PASS empty for development (emails will log to console)
SENDPULSE_SMTP_HOST=smtp-pulse.com
SENDPULSE_SMTP_PORT=465
SENDPULSE_SMTP_SECURE=true
SENDPULSE_SMTP_USER=
SENDPULSE_SMTP_PASS=
SENDPULSE_FROM_EMAIL=
SENDPULSE_REPLY_TO=
SENDPULSE_TEST_TO=

# Base URL for email verification & reset links
APP_BASE_URL=http://localhost:5173
# Production example:
# APP_BASE_URL=https://sentrawarga.my.id

# Google Sign-In (Required untuk login Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/callback

# Supabase Auth (Optional)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# AI (Gemini API)
GEMINI_API_KEY=

# Proxy
TRUST_PROXY=false
